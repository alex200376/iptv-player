{
  "name": "iptv-player",
  "version": "1.0.14",
  "description": "IPTV 全能播放器 - 支持 RTMP/M3U 等格式",
  "main": "./out/main/index.js",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "postinstall": "npx electron-rebuild -f -w electron-vlc-player",
    "pack": "electron-builder --dir",
    "dist": "electron-builder",
    "verify-asar": "node scripts/verify-asar.mjs",
    "dist:check": "npm run dist && npm run verify-asar",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.1",
    "@radix-ui/react-scroll-area": "^1.2.0",
    "@radix-ui/react-tabs": "^1.1.16",
    "@tanstack/react-virtual": "^3.14.5",
    "electron-updater": "^6.8.9",
    "electron-vlc-player": "^1.0.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@electron/asar": "^4.2.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.0",
    "electron": "^43.0.0",
    "electron-builder": "26.0.12",
    "electron-vite": "5.0.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.4.0",
    "typescript": "^5.7.0"
  }
}
